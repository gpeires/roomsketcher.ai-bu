# Cloudflare API credentials
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# D1 database name (created if it doesn't exist)
D1_DATABASE_NAME=roomsketcher-help

# Worker name (matches wrangler.toml)
WORKER_NAME=roomsketcher-help-mcp

# Optional: custom workers.dev subdomain (default: uses WORKER_NAME)
# WORKERS_SUBDOMAIN=
